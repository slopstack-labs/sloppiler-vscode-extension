{
  "name": "sloppiler",
  "displayName": "Sloppiler",
  "description": "AI-native compilation. Beyond deterministic.",
  "version": "0.0.10",
  "publisher": "slopstack-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/slopstack-labs/sloppiler-vscode-extension.git"
  },
  "homepage": "https://github.com/slopstack-labs/sloppiler-vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/slopstack-labs/sloppiler-vscode-extension/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sloppiler-panel",
          "title": "Sloppiler",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "sloppiler-panel": [
        {
          "type": "webview",
          "id": "sloppiler.sidebar",
          "name": "Compilation Control"
        }
      ]
    },
    "commands": [
      {
        "command": "sloppiler.compile",
        "title": "Sloppiler: Synthesize Binary Artifact"
      },
      {
        "command": "sloppiler.tokenmaxxFile",
        "title": "Sloppiler: Tokenmaxx Entire File"
      },
      {
        "command": "sloppiler.pickProvider",
        "title": "Sloppiler: Change Intelligence Provider"
      }
    ],
    "configuration": {
      "title": "Sloppiler",
      "properties": {
        "sloppiler.executablePath": {
          "type": "string",
          "default": "sloppiler",
          "description": "Path to the sloppiler binary."
        },
        "sloppiler.provider": {
          "type": "string",
          "default": "local",
          "enum": ["local", "openai", "google", "claude"],
          "enumDescriptions": [
            "Local Ollama instance",
            "OpenAI",
            "Google Gemini",
            "Anthropic Claude"
          ],
          "description": "Intelligence provider to route compilation intent through."
        },
        "sloppiler.model": {
          "type": "string",
          "default": "",
          "description": "Model override. Leave empty to use the provider default."
        },
        "sloppiler.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the selected provider. Alternatively set SLOPPILER_API_KEY in your environment."
        },
        "sloppiler.target": {
          "type": "string",
          "default": "linux",
          "enum": ["linux", "windows", "darwin"],
          "description": "Target OS for binary materialization."
        },
        "sloppiler.arch": {
          "type": "string",
          "default": "amd64",
          "enum": ["amd64", "arm64"],
          "description": "Target CPU architecture for binary materialization."
        },
        "sloppiler.outputPath": {
          "type": "string",
          "default": "a.out",
          "description": "Output binary path."
        },
        "sloppiler.optimistic": {
          "type": "boolean",
          "default": false,
          "description": "Engage agentic assembly co-pilot mode (requires nasm + ld)."
        },
        "sloppiler.loop": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Max fix iterations when assembly fails (use with optimistic mode)."
        },
        "sloppiler.forceIterate": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Force N improvement cycles even on successful compilation."
        },
        "sloppiler.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434/api/generate",
          "description": "Ollama API URL (only used when provider is 'local')."
        },
        "sloppiler.customModels": {
          "type": "object",
          "default": {},
          "description": "Extra models to add to each provider's list. Keys are provider names (local, openai, google, claude), values are arrays of model name strings. Example: {\"local\": [\"qwen2.5-coder:1.5b\", \"mistral\"]}"
        },
        "sloppiler.customIdentifiers": {
          "type": "object",
          "default": {},
          "description": "Extra Tokenmaxx identifier mappings, merged into (and overriding) the built-in map. Keys are the substandard identifiers, values are their tokenmaxxed replacements. Example: {\"e\": \"eventPayloadArtifact\", \"db\": \"databaseConnectionHandle\"}"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  }
}
